@page "{id:int}"
@model MySurveyApp.Pages.Admin.AdminResultsModel
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2>📊 통합 캠페인 결과: @Model.Title</h2>
        <a asp-page="Index" class="btn btn-outline-secondary">대시보드로 돌아가기</a>
    </div>

    <div class="row">
        @foreach (var res in Model.Results) {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-header @(res.Type == "Election" ? "bg-primary" : "bg-dark") text-white">
                        <h5 class="mb-0">@res.QuestionText</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">총 투표 수: @res.TotalVotes 표</p>
                        @foreach (var vote in res.VoteCounts.OrderByDescending(v => v.Value)) {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-bold">@vote.Key</span>
                                    <span>@vote.Value 표</span>
                                </div>
                                <div class="progress" style="height: 12px;">
                                    @{ var p = res.TotalVotes > 0 ? (vote.Value * 100 / res.TotalVotes) : 0; }
                                    <div class="progress-bar bg-success" style="width: @p%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>