@page
@model VoteModel
<div class="container mt-5">
    <!-- 캠페인 전체 제목 (설명은 팝업으로 이동하므로 여기서는 제거하거나 제목만 남깁니다) -->
    <div class="text-center mb-4">
        <h2>@Model.CampaignTitle</h2>
    </div>

    <!-- [중요] 투표 폼 영역: 초기 상태는 d-none (숨김) 클래스로 설정 -->
    <form method="post" id="voteForm" class="d-none">
        <input type="hidden" asp-for="Token" />

        @foreach (var q in Model.Questions)
        {
            <div class="card mb-4 shadow-sm border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@q.Text</h5>
                    <span class="badge bg-light text-dark">
                        남은 표 수: <span id="remaining-@q.Id">@q.MaxPoints</span> / @q.MaxPoints
                    </span>
                </div>
                <div class="card-body">
                    <input type="hidden" class="max-points" data-qid="@q.Id" value="@q.MaxPoints" />
                    
                    <!-- 개별 안건 설명 추가 -->
                    @if (!string.IsNullOrEmpty(q.Description))
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <small>@q.Description</small>
                        </div>
                    }
                    
                    @foreach (var opt in q.Options)
                    {
                        <div class="row align-items-center mb-3 p-2 border-bottom">
                            <div class="col-8">
                                <strong>@opt.Name</strong>
                                @if (!string.IsNullOrEmpty(opt.Description))
                                {
                                    <div class="text-muted small mt-1">📜 @opt.Description</div>
                                }
                            </div>
                            <div class="col-4 d-flex align-items-center justify-content-end">
                                <button type="button" class="btn btn-sm btn-outline-secondary me-2" onclick="changeVote(@q.Id, '@opt.Name', -1)">-</button>
                                <input type="number" name="VoteData[@q.Id][@opt.Name]" 
                                       class="form-control text-center vote-count-@q.Id" 
                                       style="width: 60px;" value="0" readonly />
                                <button type="button" class="btn btn-sm btn-outline-secondary ms-2" onclick="changeVote(@q.Id, '@opt.Name', 1)">+</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        <div id="validationMsg" class="alert alert-warning text-center">모든 질문에 정해진 표수를 모두 사용해야 제출할 수 있습니다.</div>
        <button type="submit" id="submitBtn" class="btn btn-primary btn-lg w-100" disabled>투표 제출하기</button>
    </form>
</div>

<!-- 투표 안내 팝업 모달 HTML 추가 -->
<!-- data-bs-backdrop="static" (외부 클릭 방지), data-bs-keyboard="false" (ESC 방지) -->
<div class="modal fade" id="descModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold text-primary">🚀 투표 전 안내사항</h5>
            </div>
            <div class="modal-body p-4">
                <h3 class="text-center mb-4">@Model.CampaignTitle</h3>
                
                <div class="p-3 bg-light border rounded" style="min-height: 150px; max-height: 400px; overflow-y: auto;">
                    @if (!string.IsNullOrEmpty(Model.CampaignDescription))
                    {
                        <!-- 줄바꿈 유지를 위해 style="white-space: 개추오토기 pre-wrap;" 추가 -->
                        <div class="text-secondary" style="white-space: pre-wrap; font-size: 1.1rem;">@Model.CampaignDescription</div>
                    }
                    else
                    {
                        <div class="text-center text-muted pt-5">등록된 안내 사항이 없습니다.</div>
                    }
                </div>
                
                <div class="form-check mt-4 d-flex justify-content-center">
                    <input class="form-check-input me-2" type="checkbox" id="readConfirmCheck" style="transform: scale(1.3);">
                    <label class="form-check-label fw-bold" for="readConfirmCheck">
                        위 투표 안내 사항을 모두 읽고 이해했습니다.
                    </label>
                </div>
            </div>
            <div class="modal-footer justify-content-center">
                <!-- 초기 상태는 disabled. 체크박스를 해야 활성화됨 -->
                <button type="button" class="btn btn-success btn-lg px-5" id="closeDescBtn" disabled onclick="confirmDescription()">확인 및 투표 시작</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Bootstrap 5 JS (모달 작동에 필수. Layout.cshtml에 없다면 여기에 추가) -->
    @* <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script> *@

    <script>
        // --- 팝업 모달 관련 로직 ---

        // 페이지 로드 완료 시 실행
        document.addEventListener('DOMContentLoaded', function () {
            // 1. 모달 인스턴스 생성 및 표시
            var myModal = new bootstrap.Modal(document.getElementById('descModal'));
            myModal.show();

            // 2. 체크박스 상태 변경에 따라 확인 버튼 활성화/비활성화
            const confirmCheck = document.getElementById('readConfirmCheck');
            const closeBtn = document.getElementById('closeDescBtn');
            
            confirmCheck.addEventListener('change', function() {
                closeBtn.disabled = !this.checked;
            });
        });

        // 확인 버튼 클릭 시 실행
        function confirmDescription() {
            // 1. 모달 닫기
            var modalEl = document.getElementById('descModal');
            var modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();

            // 2. 숨겨져 있던 투표 폼 표시
            document.getElementById('voteForm').classList.remove('d-none');
            
            // 3. 시각적 효과를 위해 폼으로 스크롤 이동
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }


        // --- 기존 투표 로직 (유지) ---
        function changeVote(qId, optName, delta) {
            const inputs = document.querySelectorAll(`.vote-count-${qId}`);
            const input = document.querySelector(`input[name="VoteData[${qId}][${optName}]"]`);
            const maxPoints = parseInt(document.querySelector(`.max-points[data-qid="${qId}"]`).value);
            
            let currentTotal = 0;
            inputs.forEach(i => currentTotal += parseInt(i.value));

            const newValue = parseInt(input.value) + delta;

            if (newValue >= 0 && (currentTotal + delta) <= maxPoints) {
                input.value = newValue;
                updateStatus(qId, maxPoints);
            }
        }

        function updateStatus(qId, maxPoints) {
            const inputs = document.querySelectorAll(`.vote-count-${qId}`);
            let currentTotal = 0;
            inputs.forEach(i => currentTotal += parseInt(i.value));

            document.getElementById(`remaining-${qId}`).innerText = maxPoints - currentTotal;
            validateForm();
        }

        function validateForm() {
            const questions = document.querySelectorAll('.max-points');
            let allValid = true;

            questions.forEach(q => {
                const qId = q.getAttribute('data-qid');
                const max = parseInt(q.value);
                const inputs = document.querySelectorAll(`.vote-count-${qId}`);
                let total = 0;
                inputs.forEach(i => total += parseInt(i.value));

                if (total !== max) allValid = false;
            });

            const btn = document.getElementById('submitBtn');
            const msg = document.getElementById('validationMsg');
            btn.disabled = !allValid;
            if(allValid) msg.classList.add('d-none');
            else msg.classList.remove('d-none');
        }
    </script>
}